# API Keys for MCP Servers
# Copy this file to .env and add your own API keys

# Server Selection
# Leave empty (default) to use: default servers + auto-detect servers with API keys (detection logic in mcp_client.py)
#   Default servers (no API keys): arxiv,calculator,cli-mcp-server,clinicaltrialsgov-mcp-server,context7,ddg-search,desktop-commander,fetch,filesystem,git,mcp-code-executor,mcp-server-code-runner,memory,met-museum,open-library,osm-mcp-server,pubmed,weather,whois,wikipedia
# 
# Set explicitly to use ONLY those servers (no auto-detection):
#   ENABLED_SERVERS=calculator,wikipedia,github
# 
ENABLED_SERVERS=


# Airtable
# https://github.com/felores/airtable-mcp?tab=readme-ov-file#obtaining-an-airtable-api-key
AIRTABLE_API_KEY=

# Alchemy
# https://www.alchemy.com/docs/
ALCHEMY_API_KEY=

# Brave Search
# https://brave.com/search/api/
BRAVE_API_KEY=

# E2B
# https://e2b.dev/
E2B_API_KEY=

# Exa
# https://exa.ai/
EXA_API_KEY=

# GitHub
# https://github.com/settings/tokens
GITHUB_TOKEN=

# Google Maps
# https://www.npmjs.com/package/@modelcontextprotocol/server-google-maps#setup
GOOGLE_MAPS_API_KEY=

# Google Workspace (Gmail API and Google Calendar API in Google Cloud Console)
# https://www.npmjs.com/package/@geobio/google-workspace-server#prerequisites
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Lara Translate
# https://developers.laratranslate.com/docs/introduction
LARA_ACCESS_KEY_ID=
LARA_ACCESS_KEY_SECRET=

# National Parks
# https://www.nps.gov/subjects/developer/get-started.htm
NPS_API_KEY=

# MongoDB
# Note: Add ?tls=true to the connection string for proper TLS negotiation in Docker environments
# Example: mongodb+srv://username:password@cluster.mongodb.net/?tls=true
MONGODB_CONNECTION_STRING=

# Notion
# https://github.com/makenotion/notion-mcp-server?tab=readme-ov-file#installation
NOTION_TOKEN=

# Oxylabs
# https://oxylabs.io/products/scraper-api/web
OXYLABS_USERNAME=
OXYLABS_PASSWORD=

# Slack
# https://github.com/korotovsky/slack-mcp-server/blob/master/docs/01-authentication-setup.md
SLACK_MCP_XOXC_TOKEN=
SLACK_MCP_XOXD_TOKEN=

# Twelve Data
# https://twelvedata.com/docs
TWELVE_DATA_API_KEY=

# Weather Data
# https://www.weatherapi.com/
WEATHER_API_KEY=




# ---------------------------------------------------------------------------
# Agent Harness (services/agent-harness) — the model being evaluated
# ---------------------------------------------------------------------------
# LLM_API_KEY: any LiteLLM-compatible key. Comma-separated values are rotated.
# LLM_BASE_URL: endpoint that speaks OpenAI Chat Completions (e.g. a LiteLLM proxy).
LLM_API_KEY=
LLM_BASE_URL=

# Where the agent-environment docker container is reachable. Default works
# when you run `make run-docker` on the same host as the harness.
MCP_SANDBOX_URL=http://localhost:1984

# Request timeouts in ms (optional). Raise these for slow / heavy-reasoning
# models so long thinking calls and large tool payloads aren't cut off mid-run.
# Defaults: tool call 60000, list-tools 180000, LLM call 600000.
# TOOL_CALL_TIMEOUT_MS=60000
# LIST_TOOLS_TIMEOUT_MS=180000
# LLM_TIMEOUT_MS=600000

# ---------------------------------------------------------------------------
# Evaluation / Diagnostic scripts (services/scoring, services/diagnostics)
# ---------------------------------------------------------------------------
# Falls back to LLM_API_KEY / LLM_BASE_URL if EVAL_LLM_* are not set.
EVAL_LLM_MODEL=gemini/gemini-3.1-pro-preview
EVAL_LLM_API_KEY=
EVAL_LLM_BASE_URL=




# Agent harness server port (TypeScript service in services/agent-harness)
PORT=3001
# run_eval.py reaches the harness at http://localhost:$PORT by default;
# set HARNESS_URL to override (e.g. if the harness runs on another host/port).
# HARNESS_URL=http://localhost:3001

# Logging
LOG_LEVEL=info
